{
  "name": "yuudashboard-feeds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RSS → LLM 工作流 → Hugo 每日简报 抓取管道（不参与站点构建）",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node v2/index.js",
    "daily": "node v2/index.js --job=daily",
    "dry": "node v2/index.js --job=daily --dry-run",
    "ingest-only": "node v2/index.js --job=daily --stop-after=ingest",
    "finance": "node v2/index.js --job=finance",
    "finance:dry": "node v2/index.js --job=finance --dry-run",
    "finance:ingest-only": "node v2/index.js --job=finance --stop-after=ingest",
    "sectors": "node v2/index.js --job=sectors",
    "focus": "node v2/index.js --job=focus",
    "linkage": "node v2/index.js --job=linkage"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "iconv-lite": "^0.6.3",
    "js-yaml": "^4.1.0",
    "undici": "^8.6.0"
  }
}
