    "PingFang SC", "Microsoft YaHei", sans-serif;--hairline:rgba(0, 0, 0, 0.1);--hairline-strong:rgba(0, 0, 0, 0.18);--text-primary:#1d1d1f;--text-secondary:#6e6e73;--surface:#f5f5f7}@media(prefers-color-scheme:dark){:root{--hairline:rgba(255, 255, 255, 0.14);--hairline-strong:rgba(255, 255, 255, 0.24);--text-primary:#f5f5f7;--text-secondary:#a1a1a6;--surface:rgba(255, 255, 255, 0.06)}}.hero{text-align:center;padding:5rem 1rem 3.5rem}.hero-title{font-size:clamp(2.5rem,7vw,4rem);font-weight:700;letter-spacing:-.04em;line-height:1.05;margin:0 0 .6rem;color:var(--text-primary)}.hero-subtitle{color:var(--text-secondary);font-size:clamp(1.05rem,2vw,1.35rem);font-weight:400;margin:0;letter-spacing:-.01em}.book-article h2{font-size:clamp(1.5rem,3vw,2rem);font-weight:600;letter-spacing:-.02em;margin:4rem 0 1.5rem;color:var(--text-primary)}.bookshelf{margin:1rem 0 2rem;border-top:1px solid var(--hairline)}.book-row{display:flex;align-items:baseline;gap:1.5rem;padding:1.6rem .25rem;border-bottom:1px solid var(--hairline);text-decoration:none;color:inherit;transition:padding-left .3s ease,background .3s ease}.book-row:hover{padding-left:1rem;background:var(--surface)}.book-row-title{flex:none;font-size:1.3rem;font-weight:600;letter-spacing:-.015em;color:var(--text-primary)}.book-row-meta{flex:none;font-size:.9rem;color:var(--text-secondary);min-width:8rem}.book-row-desc{flex:auto;font-size:.92rem;line-height:1.5;color:var(--text-secondary);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.book-row-arrow{flex:none;color:var(--text-secondary);font-size:1.2rem;transition:transform .3s ease,color .3s ease}.book-row:hover .book-row-arrow{transform:translateX(4px);color:var(--color-link)}.category-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.2rem;margin:1.5rem 0 2rem}.category-card{padding:1.8rem 1.5rem;border:1px solid var(--hairline);border-radius:12px;cursor:pointer;transition:transform .3s ease,box-shadow .3s ease,border-color .3s ease}.category-card:hover{transform:translateY(-4px)scale(1.02);box-shadow:0 8px 24px rgba(0,0,0,8%);border-color:var(--color-link)}.category-card:active{transform:scale(1.05)}.category-card-icon{display:block;font-size:2.4rem;margin-bottom:.6rem}.category-card-title{font-size:1.2rem;font-weight:600;color:var(--text-primary);margin:0 0 .3rem}.category-card-count{display:inline-block;padding:.1rem .6rem;border-radius:999px;background:var(--surface);font-size:.78rem;color:var(--text-secondary);margin-bottom:.5rem}.category-card-desc{font-size:.88rem;line-height:1.5;color:var(--text-secondary);margin:0}.bookshelf[data-category]{border-top:1px solid var(--hairline)}.back-btn{display:inline-flex;align-items:center;gap:.3rem;margin:1rem .25rem .5rem;padding:.45rem 1rem;border:1px solid var(--hairline);border-radius:8px;background:0 0;cursor:pointer;font-size:.88rem;font-family:var(--font-sans);color:var(--text-secondary);transition:color .2s,border-color .2s}.back-btn:hover{color:var(--color-link);border-color:var(--color-link)}@keyframes zoomIn{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}@keyframes zoomOut{from{opacity:1;transform:scale(1)}to{opacity:0;transform:scale(.92)}}@keyframes fadeSlideIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}.zoom-in{animation:zoomIn .3s ease-out forwards}.zoom-out{animation:zoomOut .2s ease-in forwards}@media(prefers-color-scheme:dark){.category-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.3)}}.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1px;margin:1.5rem 0 2rem;background:var(--hairline);border:1px solid var(--hairline);border-radius:18px;overflow:hidden}.card{display:flex;flex-direction:column;padding:1.6rem 1.5rem;background:var(--body-background);text-decoration:none;color:inherit;transition:background .2s ease}.card:hover{background:var(--surface)}.card-title{margin:0 0 .5rem;font-size:1.1rem;font-weight:600;letter-spacing:-.01em;line-height:1.3;color:var(--text-primary)}.card-desc{margin:0 0 1rem;font-size:.88rem;line-height:1.55;color:var(--text-secondary);flex-grow:1}.card-meta{display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;font-size:.8rem;color:var(--text-secondary)}.card-meta time{font-variant-numeric:tabular-nums}.chip{display:inline;color:var(--color-link);background:0 0;border:none;padding:0;font-size:inherit;text-decoration:none}.chip::before{content:"#";opacity:.5}.chip:hover{text-decoration:underline}.chip-lg{font-size:.95rem}.chip-count{font-variant-numeric:tabular-nums;color:var(--text-secondary);font-size:.85em}.chip-count::before{content:"·";margin:0 .2em;opacity:.5}.tag-cloud{display:flex;flex-wrap:wrap;gap:.8rem 1.5rem;margin:2.5rem 0;line-height:2}.recent-list{margin:.5rem 0 1rem;border-top:1px solid var(--hairline)}.recent-item{display:flex;justify-content:space-between;align-items:baseline;gap:1.5rem;padding:1.1rem .25rem;border-bottom:1px solid var(--hairline);text-decoration:none;color:inherit;transition:padding-left .25s ease}.recent-item:hover{padding-left:.75rem}.recent-item-main{flex:auto;min-width:0}.recent-item-title{margin:0;font-size:1.05rem;font-weight:500;letter-spacing:-.01em;color:var(--text-primary)}.recent-item-desc{display:none}.recent-item-meta time{flex:none;font-size:.85rem;color:var(--text-secondary);font-variant-numeric:tabular-nums;white-space:nowrap}.recent-empty{color:var(--text-secondary);padding:2rem 0}.section-link{margin:1.5rem 0 1rem}.section-link a{color:var(--color-link);font-size:.95rem;text-decoration:none}.section-link a:hover{text-decoration:underline}.post-header{margin-bottom:2.5rem;padding-bottom:0}.post-title{margin:0 0 .8rem;font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;letter-spacing:-.03em;line-height:1.15;color:var(--text-primary)}.post-meta{display:flex;flex-wrap:wrap;align-items:center;gap:.8rem;font-size:.88rem;color:var(--text-secondary)}.post-meta time,.post-meta .meta-author,.post-meta 