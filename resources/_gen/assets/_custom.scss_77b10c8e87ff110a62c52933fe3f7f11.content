@charset "UTF-8";.markdown ul,.markdown ol{padding-left:1.5rem;margin:.75rem 0}.markdown li{margin:.25rem 0;line-height:1.7}.markdown ul>li{list-style-type:disc}.markdown ul>li>ul>li{list-style-type:circle}.markdown ul>li>ul>li>ul>li{list-style-type:square}.markdown ol>li{list-style-type:decimal}.markdown li>ul,.markdown li>ol{margin:.25rem 0 .25rem 1rem}.markdown p{text-align:justify}.markdown{font-size:1rem;line-height:1.8}.markdown h1{font-weight:700;letter-spacing:-.02em;border-bottom:2px solid var(--gray-200);padding-bottom:.3rem}.markdown h2{margin-top:2.4em;font-weight:700}.markdown h3{font-weight:600;margin-top:2rem;padding:.4rem .8rem;border-left:4px solid var(--color-link);background:var(--gray-100);border-radius:0 6px 6px 0}.markdown p{margin-bottom:1em}.markdown code{border-radius:.35rem}.markdown table{display:table;width:auto;max-width:100%;margin:0 auto}.markdown table th,.markdown table td{text-align:center;padding:.4rem .8rem}.markdown table.grid-world{width:auto;margin:1rem auto}.markdown table.grid-world td{width:2.5rem;height:2.5rem;text-align:center;border:1px solid var(--gray-200)}.markdown img{display:block;margin:1.5rem auto .5rem;max-width:90%;box-shadow:0 2px 8px rgba(0,0,0,.1)}.markdown p.caption{text-align:center;font-size:.8rem;color:var(--gray-500);margin-top:.3rem;margin-bottom:1.5rem}.markdown .solution{border-left:4px solid #2e7d32;background:#e8f5e9;padding:.8rem 1.2rem;margin:1rem 0;border-radius:0 6px 6px 0}@media(prefers-color-scheme:dark){.markdown .solution{border-left-color:#66bb6a;background:rgba(46,125,50,.15)}}.markdown .proof{border-left:4px solid #5c6bc0;background:#eef0f7;padding:.8rem 1.2rem;margin:1rem 0;border-radius:0 6px 6px 0}@media(prefers-color-scheme:dark){.markdown .proof{border-left-color:#7986cb;background:rgba(92,107,192,.15)}}.markdown .algorithm{border:1px solid var(--gray-200);border-radius:6px;margin:1.5rem 0;overflow:hidden}.markdown .algorithm .alg-title{display:block;font-weight:700;font-size:.85rem;p