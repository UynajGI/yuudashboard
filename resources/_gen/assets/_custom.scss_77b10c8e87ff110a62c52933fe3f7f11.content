solid #5856d6}.element.theorem{border-left:3px solid #007aff}.element.example{border-left:3px solid #34c759}.element.key-point{border-left:3px solid #ff9500;background:rgba(255,149,0,5%)}.element.algorithm{border-left:3px solid #30b0c8}.algorithm-body pre.pseudocode{margin:.5rem 0 0;padding:0;background:0 0;border:none}.book-cover{text-align:center;padding:3rem 1rem 2rem}.book-cover-title{font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;letter-spacing:-.03em;margin:0 0 .5rem;color:var(--text-primary)}.book-cover-subtitle{color:var(--text-secondary);font-size:1.05rem;margin:0 0 .4rem}.book-cover-author{color:var(--text-secondary);font-size:.9rem;margin:0}.book-toc-list{margin:1rem 0 2rem;border-top:1px solid var(--hairline)}.toc-row{display:flex;align-items:baseline;gap:1rem;padding:1rem .25rem;border-bottom:1px solid var(--hairline);text-decoration:none;color:inherit;transition:padding-left .25s ease,background .25s ease}.toc-row:hover{padding-left:.75rem;background:var(--surface)}.toc-row:hover .toc-row-arrow{transform:translateX(4px);color:var(--color-link)}.toc-row-title{flex:none;font-weight:500;color:var(--text-primary);white-space:nowrap}.toc-row-desc{flex:auto;font-size:.88rem;color:var(--text-secondary);line-height:1.5;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.toc-row-arrow{flex:none;color:var(--text-secondary);transition:transform .25s ease,color .25s ease}.book-toc-content{font-size:.85rem}.book-toc-content nav#TableOfContents ul{padding-left:.8rem;list-style:none}.book-toc-content nav#TableOfContents li{margin:.25rem 0}.book-toc-content nav#TableOfContents a{display:block;color:var(--text-secondary);text-decoration:none;line-height:1.4;padding:.1rem 0}.book-toc-content nav#TableOfContents a:hover{color:var(--color-link)}.book-toc-content nav#TableOfContents>ul>li>a{font-weight:500;color:var(--text-primary)}.book-search{position:relative}.book-search input{padding-right:3rem}.book-search-kbd{position:absolute;top:50%;right:.5rem;transform:translateY(-50%);padding:.1rem .4rem;font-size:.7rem;font-family:var(--font-sans);color:var(--text-secondary);background:var(--surface);border:1px solid var(--hairline);border-radius:4px;line-height:1.4;pointer-events:none}.menu-about{padding:.5rem 0 0}.menu-about a{font-size:.9rem;color:var(--text-secondary)}.menu-about a:hover{color:var(--color-link)}.menu-social{display:flex;gap:.5rem;padding:.75rem 0 0;margin-top:1rem;border-top:1px solid var(--hairline)}.menu-social-link{display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;color:var(--text-secondary);transition:color .15s,background .15s}.menu-social-link:hover{color:var(--color-link);background:var(--surface)}.book-part{text-align:center;padding:3rem 1rem 2rem}.book-part-label{font-size:.8rem;text-transform:uppercase;letter-spacing:.2em;color:var(--text-secondary);margin:0 0 .5rem}.book-part-title{font-size:1.8rem;font-weight:700;margin:0 0 .75rem}.book-part-desc{font-size:1rem;color:var(--text-secondary);max-width:480px;margin:0 auto}.part-chapters{display:flex;flex-direction:column;gap:.75rem;margin-top:1.5rem}.part-chapter{display:flex;flex-wrap:wrap;align-items:baseline;gap:.5rem 1rem;padding:1rem 1.25rem;border:1px solid var(--hairline);border-radius:8px;text-decoration:none;color:inherit;transition:border-color .2s,background .2s}.part-chapter:hover{border-color:var(--color-link);background:var(--surface)}.part-chapter-num{font-size:.75rem;color:var(--text-secondary);min-width:3rem}.part-chapter-title{font-weight:600}.part-chapter-desc{width:100%;font-size:.85rem;color:var(--text-secondary)}.rough-container{margin:1.5rem 0;text-align:center}.rough-container canvas{max-width:100%;height:auto;border-radius:8px}.book-footer{margin-top:3rem;padding:1.25rem 0;border-top:1px solid var(--hairline);font-size:.8rem;color:var(--text-secondary)}.book-footer-inner{display:flex;flex-direction:column;gap:.5rem}.footer-text{line-height:1.6}.footer-bottom{display:flex;align-items:center;gap:.6rem}.book-footer .flex.flex-wrap{margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--hairline);font-size:.9rem}.book-footer .flex.flex-wrap a{display:inline-flex;align-items:center;gap:.4rem;color:var(--color-link);text-decoration:none}.book-footer .flex.flex-wrap a:hover{text-decoration:underline}.book-footer .flex.flex-wrap .book-icon{width:1rem;height:1rem;opacity:.6}.sort-bar{display:flex;align-items:center;gap:.4rem;padding:.5rem 0 1rem;border-bottom:1px solid var(--gray-200);margin-bottom:.5rem}.sort-bar-label{font-size:.8rem;color:var(--gray-500);margin-right:.2rem}.sort-btn{font-size:.78rem;padding:.2rem .6rem;border:1px solid var(--gray-300);border-radius:4px;background:0 0;color:var(--gray-500);cursor:pointer;transition:all .15s}.sort-btn:hover{border-color:var(--color-link);color:var(--color-link)}.sort-btn.active{background:var(--color-link);border-color:var(--color-link);color:#fff}